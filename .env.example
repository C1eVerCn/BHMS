# BHMS baseline settings
BHMS_DB_PATH=data/bhms.db
BHMS_DEFAULT_SEQ_LEN=30
BHMS_DEFAULT_PAGE_SIZE=10
BHMS_EOL_RATIO=0.8

# Graph backend: set to memory if Neo4j is unavailable
BHMS_GRAPH_BACKEND=neo4j
BHMS_NEO4J_URI=bolt://localhost:7687
BHMS_NEO4J_USER=neo4j
BHMS_NEO4J_PASSWORD=bhmsneo4j
BHMS_NEO4J_DATABASE=neo4j

# Frontend optional override
# VITE_API_BASE_URL=http://localhost:8000/api/v1
